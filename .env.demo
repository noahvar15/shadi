# ============================================================
# DEMO / LOCAL DEVELOPMENT ONLY — safe to commit
# No real PHI, no real EHR, no real GPU inference required.
#
# This file is read automatically — no cp needed.
# pydantic-settings tries .env first (git-ignored personal override),
# then falls back here.  Create .env only if you need to override a value.
# ============================================================

# ── Database (Docker Compose postgres service or local Postgres) ──────────────
DATABASE_URL=postgresql+asyncpg://shadi:shadi@localhost:5432/shadi

# ── Redis (Docker Compose redis service or local Redis) ───────────────────────
REDIS_URL=redis://localhost:6379/0
INTAKE_QUEUE=arq:intake

# ── API ───────────────────────────────────────────────────────────────────────
# A made-up string is fine for local demo — no external service validates this.
API_SECRET_KEY=shadi-hackathon-demo-2026-not-for-production

# ── Agent inference ───────────────────────────────────────────────────────────
# MOCK_LLM=true means agents return fixture diagnoses without calling any model.
# Flip to false only when Ollama + vLLM are running and models are pulled.
MOCK_LLM=true

OLLAMA_BASE_URL=http://localhost:11434/v1
VLLM_BASE_URL=http://localhost:8080/v1

# ── EHR / FHIR (intentionally blank — EHR stays disabled for demo) ────────────
FHIR_BASE_URL=
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_TOKEN_URL=
NOTIFICATION_ENDPOINT=
FHIR_WEBHOOK_SECRET=

# ─── EHR Connection ───────────────────────────────────────────────────────────
# FHIR R4 base URL for Epic/Cerner (e.g. https://your-epic-instance/api/FHIR/R4)
FHIR_BASE_URL=

# OAuth2 client credentials for SMART on FHIR
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_TOKEN_URL=

# Public URL the EHR calls for Subscription rest-hook (e.g. https://your-host/fhir/notify). Required when FHIR MCP is enabled.
NOTIFICATION_ENDPOINT=

# Shared secret for HMAC-SHA256 on POST /fhir/notify (header X-Shadi-Signature: sha256=<hex>). Required when FHIR MCP is enabled.
FHIR_WEBHOOK_SECRET=

# ─── Mock EHR (issue #70) — ``python -m tools.mock_ehr`` (default port 9001) ─
# Point Shadi FHIR_BASE_URL / FHIR_TOKEN_URL / FHIR_CLIENT_* at this service for local demos.
# MOCK_EHR_CLIENT_ID=mock-ehr-client
# MOCK_EHR_CLIENT_SECRET=mock-ehr-secret
# MOCK_EHR_SHADI_NOTIFY_URL=http://127.0.0.1:8000/fhir/notify
# MOCK_EHR_SHADI_WEBHOOK_SECRET=  # optional; match FHIR_WEBHOOK_SECRET if signing notify

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shadi:shadi@localhost:5432/shadi

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# arq queue for case intake → diagnostic pipeline (api.config.Settings, FHIR MCP enqueue, worker job name `run_intake`)
INTAKE_QUEUE=arq:intake

# Set to 1 to accept POST /cases without a valid FHIR bundle (stub CaseObject; see cross-track-dependencies DEP-1)
# SHADI_STUB_CASE_INTAKE=1

# ─── vLLM / Specialist Models ─────────────────────────────────────────────────
# Serves meditron:70b in FP4 with hot-swappable LoRA adapters (ADR-001, ADR-002)
# Absolute path to Meditron-70B weights on local disk
MODEL_BASE_PATH=/models/meditron-70b

# Absolute path to LoRA adapter directory (subdirs: cardiology, neurology, pulmonology, toxicology)
LORA_ADAPTERS_PATH=/models/adapters

# vLLM server endpoint
VLLM_BASE_URL=http://localhost:8080/v1

# ─── Ollama / All Other Agents ────────────────────────────────────────────────
# Serves all non-specialist models. Pull models on first boot with:
#   docker exec shadi-ollama-1 ollama pull alibayram/medgemma:27b
#   docker exec shadi-ollama-1 ollama pull qwen2.5:7b
#   docker exec shadi-ollama-1 ollama pull nomic-embed-text
#   docker exec shadi-ollama-1 ollama pull phi4:14b
#   docker exec shadi-ollama-1 ollama pull deepseek-r1:32b
OLLAMA_BASE_URL=http://localhost:11434/v1

# ─── Model Assignments (see ADR-002) ──────────────────────────────────────────
# Image analysis agent (multimodal — radiographs, ECGs, CT scouts)
IMAGE_MODEL=alibayram/medgemma:27b

# Intake agent (SNOMED/LOINC/RxNorm extraction from triage notes)
INTAKE_MODEL=qwen2.5:7b

# Evidence grounding — embedding model for PubMed/guidelines vector search
# Claim evaluation reuses vLLM/meditron; no separate model needed
EVIDENCE_EMBED_MODEL=nomic-embed-text

# Safety veto agent (contraindication / drug interaction constraint checking)
SAFETY_MODEL=phi4:14b

# Orchestrator — A2A debate synthesis, differential ranking, FHIR report writing
ORCHESTRATOR_MODEL=deepseek-r1:32b

# ─── Evidence Corpus ──────────────────────────────────────────────────────────
# Path to local PubMed + clinical guidelines BM25 index
EVIDENCE_INDEX_PATH=/data/evidence_index

# NCBI Entrez API key for PubMed queries (https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Required. Generate e.g. openssl rand -hex 32 — must not be change-me / REPLACE_ME placeholders.
API_SECRET_KEY=dev-local-only-set-a-long-random-secret

# ─── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

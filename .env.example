# ─── EHR Connection ───────────────────────────────────────────────────────────
# FHIR R4 base URL for Epic/Cerner (e.g. https://your-epic-instance/api/FHIR/R4)
FHIR_BASE_URL=

# OAuth2 client credentials for SMART on FHIR
FHIR_CLIENT_ID=
FHIR_CLIENT_SECRET=
FHIR_TOKEN_URL=

# Public URL the EHR calls for Subscription rest-hook (must match POST /fhir/notify exposure)
NOTIFICATION_ENDPOINT=https://shadi.local/fhir/notify

# Shared secret for HMAC on POST /fhir/notify when verification is enabled (FHIR MCP)
FHIR_WEBHOOK_SECRET=

# ─── Mock EHR (issue #70) — ``python -m tools.mock_ehr`` (default port 9001) ─
# Point Shadi FHIR_BASE_URL / FHIR_TOKEN_URL / FHIR_CLIENT_* at this service for local demos.
# MOCK_EHR_CLIENT_ID=mock-ehr-client
# MOCK_EHR_CLIENT_SECRET=mock-ehr-secret
# MOCK_EHR_SHADI_NOTIFY_URL=http://127.0.0.1:8000/fhir/notify
# MOCK_EHR_SHADI_WEBHOOK_SECRET=  # optional; match FHIR_WEBHOOK_SECRET if signing notify

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shadi:shadi@localhost:5432/shadi

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# arq queue for case intake → diagnostic pipeline (must match api + worker + unit tests)
INTAKE_QUEUE=arq:intake

# Set to 1 to accept POST /cases without a valid FHIR bundle (stub CaseObject; see cross-track-dependencies DEP-1)
# SHADI_STUB_CASE_INTAKE=1

# ─── Optional vLLM (profile vllm-lora — not used by agents; see ADR-003, ADR-004) ─
# MODEL_BASE_PATH=/models/meditron-70b   # HF layout; preflight: ./scripts/check_vllm_model_base.sh
# LORA_ADAPTERS_PATH=/models/adapters
# VLLM_BASE_URL=http://localhost:8080/v1

# ─── Ollama (all inference including specialists + claim eval) ───────────────
# Pull on first boot (adjust container name from `docker compose ps`):
#   docker compose exec ollama ollama pull meditron:70b
#   docker compose exec ollama ollama pull alibayram/medgemma:27b
#   docker compose exec ollama ollama pull qwen2.5:7b
#   docker compose exec ollama ollama pull nomic-embed-text
#   docker compose exec ollama ollama pull phi4:14b
#   docker compose exec ollama ollama pull deepseek-r1:32b
OLLAMA_BASE_URL=http://localhost:11434/v1

# Specialists ×4 + evidence claim evaluation (ADR-004)
MEDITRON_MODEL=meditron:70b

# ─── Model Assignments (see ADR-002, ADR-004) ─────────────────────────────────
# Image analysis agent (multimodal — radiographs, ECGs, CT scouts)
IMAGE_MODEL=alibayram/medgemma:27b

# Intake agent (SNOMED/LOINC/RxNorm extraction from triage notes)
INTAKE_MODEL=qwen2.5:7b

# Evidence grounding — embedding model for PubMed/guidelines vector search
# Claim evaluation uses MEDITRON_MODEL on Ollama
EVIDENCE_EMBED_MODEL=nomic-embed-text

# Safety veto agent (contraindication / drug interaction constraint checking)
SAFETY_MODEL=phi4:14b

# Orchestrator — A2A debate synthesis, differential ranking, FHIR report writing
ORCHESTRATOR_MODEL=deepseek-r1:32b

# ─── Live inference (MOCK_LLM=false) ─────────────────────────────────────────
# Long HTTP read timeout for 70B-class models (seconds)
# LLM_HTTP_TIMEOUT_SECONDS=600
# Ollama /api/embeddings timeout (seconds)
# OLLAMA_EMBED_TIMEOUT_SECONDS=180
# false = run specialists one-by-one (recommended for single-GPU Ollama)
# SPECIALISTS_PARALLEL=false

# ─── Evidence Corpus ──────────────────────────────────────────────────────────
# Path to local PubMed + clinical guidelines BM25 index
EVIDENCE_INDEX_PATH=/data/evidence_index

# NCBI Entrez API key for PubMed queries (https://www.ncbi.nlm.nih.gov/account/)
NCBI_API_KEY=

# ─── API ──────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Required. Generate e.g. openssl rand -hex 32 — must not be change-me / REPLACE_ME placeholders.
API_SECRET_KEY=dev-local-only-set-a-long-random-secret

# ─── Dashboard ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Observability ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

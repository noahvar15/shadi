.DS_Store

# Node / dashboard
dashboard/node_modules/
dashboard/.next/
dashboard/out/

# Models — weights are too large for git; use DVC or manual placement
models/adapters/*/adapter_model.safetensors
models/adapters/*/adapter_model.bin
/models/

# Evidence index — built locally, not committed
/data/


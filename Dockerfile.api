# API + arq worker image (minimal runtime deps — full dev install: pip install -e ".[dev]" locally).
# Dependencies are listed explicitly (not `pip install .`) because the project root pulls vLLM/torch
# and other GPU stacks that are not required for the HTTP API or arq worker.
FROM python:3.11-slim-bookworm
WORKDIR /app
RUN apt-get update && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

COPY config.py ./
COPY agents ./agents
COPY a2a ./a2a
COPY api ./api
COPY shadi_fhir ./shadi_fhir
COPY tasks ./tasks
COPY tools ./tools
COPY pyproject.toml README.md ./

RUN pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir \
    "fastapi>=0.115.0" \
    "uvicorn[standard]>=0.32.0" \
    "pydantic>=2.9.0" \
    "pydantic-settings>=2.6.0" \
    "fhir.resources>=7.1.0" \
    "httpx>=0.27.0" \
    "anyio>=4.6.0" \
    "redis>=5.2.0" \
    "arq>=0.26.0" \
    "asyncpg>=0.30.0" \
    "structlog>=24.4.0"

RUN useradd --create-home --shell /bin/bash --uid 1000 app \
    && chown -R app:app /app
USER app

ENV PYTHONPATH=/app
EXPOSE 8000
CMD ["uvicorn", "api.main:app", "--host", "0.0.0.0", "--port", "8000"]

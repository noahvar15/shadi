# ============================================================
# Dashboard — LOCAL DEVELOPMENT
#
# Usage:
#   cp dashboard/.env.local.example dashboard/.env.local
# ============================================================

# Points the Next.js /api/* rewrite at the FastAPI backend.
NEXT_PUBLIC_API_URL=http://localhost:8000

# DO NOT set NEXT_PUBLIC_MOCK_API here.
# Leaving it absent keeps MSW disabled so real API calls go to FastAPI.
# Set to "true" only if you want to run the dashboard without a backend.
# NEXT_PUBLIC_MOCK_API=true

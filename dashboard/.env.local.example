# ============================================================
# Dashboard — LOCAL DEVELOPMENT (optional — no copy needed)
#
# Both variables below have working defaults built into the source:
#   NEXT_PUBLIC_API_URL  → defaults to http://localhost:8000
#   NEXT_PUBLIC_MOCK_API → absent = MSW off (real API calls go to FastAPI)
#
# You only need this file if you want to override a default, e.g.:
#   - run against a remote backend
#   - enable MSW offline mode (NEXT_PUBLIC_MOCK_API=true)
#
# If you do need it: cp dashboard/.env.local.example dashboard/.env.local
# ============================================================

# Server-side rewrite destination — Next.js rewrites /api/* → this URL.
# Default: http://localhost:8000 (set in next.config.ts).
# API_URL=http://localhost:8000

# DO NOT set NEXT_PUBLIC_MOCK_API — leaving it absent keeps MSW disabled.
# NEXT_PUBLIC_MOCK_API=true
